# SPOT_SUPABASE_ANON_KEY=

# Yellow Metal official Supabase (server-only — analytics, plans, sessions)
# Required on Vercel. Prefer a rotatable sb_secret_… key over legacy service_role.
YM_SUPABASE_URL=https://lgrgechpbniqfrlrfndm.supabase.co
# YM_SUPABASE_SERVICE_ROLE_KEY=

# Daily retention cron (same value in Vercel → used as Authorization: Bearer …)
# CRON_SECRET=

# Prefer ADMIN_PASSWORD_HASH in production; ADMIN_SECRET is local/dev fallback
ADMIN_SECRET=change-me-in-production

# Required: dedicated ≥32-char secret for signing admin session cookies (do NOT reuse ADMIN_SECRET)
ADMIN_SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Optional scrypt hash (preferred over plaintext ADMIN_SECRET)
# ADMIN_PASSWORD_HASH=scrypt$16384$8$1$...

# Optional MFA — base32 secret for authenticator apps
# ADMIN_TOTP_SECRET=
